# astropath-dns-relay — example environment (SPEC §10, T-M0-09).
#
# LOCAL DEVELOPMENT ONLY. Real deployment env is delivered ansible-vault'd
# (SPEC §10.2, §15.4). Copy this file, fill in real values, and keep the copy
# OUT of git.
#
# Every value below is an OBVIOUS PLACEHOLDER (CHANGE_ME). No real or realistic
# secret ever belongs in this file. Secrets are redacted to <REDACTED> anywhere
# else; here they are simply absent.
#
# All variables use the ASTROPATH_ prefix (SPEC §1.4) and are consumed by
# astropath.settings.Settings.

# ---------------------------------------------------------------------------
# Bootstrap secrets (SecretStr — required; never logged) — SPEC §10.2
# ---------------------------------------------------------------------------

# Async SQLAlchemy DSN. MUST use the async driver scheme `postgresql+asyncpg://`
# (never plain `postgresql://`). The host `postgres` and the password below must
# match the postgres service in docker-compose.example.yml.
ASTROPATH_DATABASE_DSN=postgresql+asyncpg://astropath:CHANGE_ME@postgres:5432/astropath

# Ordered Fernet keylist, PRIMARY FIRST (comma-separated for rotation; SPEC §7).
# Each entry is a 44-char urlsafe-base64 Fernet key. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ASTROPATH_CREDENTIAL_KEK=CHANGE_ME

# argon2id hash that seeds the bootstrap admin credential (SPEC §6.3). Store the
# HASH, never the plaintext password. Generate with:
#   python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('your-admin-password'))"
#
# COMPOSE $-ESCAPING: this file is loaded via `env_file:` in
# docker-compose.example.yml, and Docker Compose interpolates `$...`. An argon2
# hash is full of `$` (`$argon2id$v=19$m=...`), so DOUBLE every `$` as `$$` in the
# real value here or Compose eats the fields as unset variables and the hash
# arrives mangled (admin login then fails). Shape (placeholders, not a real hash):
#   ASTROPATH_ADMIN_PASSWORD_HASH=$$argon2id$$v=19$$m=65536,t=3,p=4$$<salt>$$<hash>
ASTROPATH_ADMIN_PASSWORD_HASH=CHANGE_ME

# Starlette SessionMiddleware signing secret (SPEC §8.2). High-entropy random.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
ASTROPATH_SESSION_SECRET=CHANGE_ME

# ---------------------------------------------------------------------------
# Non-secret runtime configuration (SPEC §10.2). Defaults shown; safe to keep.
# ---------------------------------------------------------------------------

# nginx source IP/CIDR trusted for X-Forwarded-* (uvicorn forwarded_allow_ips,
# SPEC §8.6). Prefer an explicit source over "*". Default is localhost-only.
ASTROPATH_FORWARDED_ALLOW_IPS=127.0.0.1

# RFC2136 DNS listener bind + port (UDP + TCP). Port 53 is privileged; the
# container runs non-root, so binding it needs NET_BIND_SERVICE (granted in the
# compose file) or a higher port here.
ASTROPATH_DNS_BIND=0.0.0.0
ASTROPATH_DNS_PORT=53

# FastAPI management/admin HTTP plane bind + port.
ASTROPATH_HTTP_BIND=0.0.0.0
ASTROPATH_HTTP_PORT=8080

# Logging (SPEC §10.2 / logging_config). LEVEL: DEBUG|INFO|WARNING|ERROR.
ASTROPATH_LOG_LEVEL=INFO
ASTROPATH_LOG_FORMAT=text
